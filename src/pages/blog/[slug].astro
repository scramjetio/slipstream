---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
	<article>
		<header class="mb-10 text-center">
			<time class="text-sm font-medium text-gray-500 mb-4 block">
				{new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(entry.data.date)}
			</time>
			<h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 mb-6">{entry.data.title}</h1>
			<p class="text-gray-500">By {entry.data.author}</p>
		</header>
		
		<div class="prose prose-lg prose-blue mx-auto prose-headings:font-bold prose-headings:tracking-tight prose-a:text-blue-600 hover:prose-a:text-blue-500">
			<Content />
		</div>
	</article>
</Layout>
